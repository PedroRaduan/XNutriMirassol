{
  "name": "xnutri",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^20.19 || ^22.12 || >=24.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "vercel-build": "npm run production:check && prisma generate && prisma migrate deploy && next build",
    "hostinger-build": "npm run production:check && prisma migrate deploy && npm run build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:db:reset": "tsx scripts/reset-test-db.ts",
    "test:e2e": "npm run test:db:reset && playwright test",
    "test:e2e:ui": "npm run test:db:reset && playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:all": "npm run lint && npm run typecheck && npm run db:validate && npm run test && npm run test:e2e",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "production:check": "tsx scripts/check-production-env.ts",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:status": "prisma migrate status",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "admin:create": "tsx scripts/create-admin.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.18.0",
    "mercadopago": "^3.1.0",
    "nanoid": "^5.1.11",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "sanitize-html": "^2.17.5",
    "slugify": "^1.6.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "@prisma/dev": {
      "@hono/node-server": "1.19.13"
    },
    "next": {
      "postcss": "8.5.16"
    }
  }
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  ADMIN
}

enum AdminRole {
  ADMIN
  MANAGER
  CASHIER
  VIEWER
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  AWAITING_PICKUP
  SHIPPED
  DELIVERED
  CANCELED
  REFUNDED
}

enum ShippingType {
  DELIVERY
  PICKUP
}

enum ShippingProvider {
  CORREIOS
  MANUAL
  PICKUP
}

enum PaymentProvider {
  MERCADO_PAGO
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BOLETO
  UNKNOWN
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CANCELED
}

enum InventoryMovementType {
  STOCK_IN
  STOCK_OUT
  RESERVATION
  RELEASE
  ADJUSTMENT
  RETURN
}

enum BannerLocation {
  HOME_HERO
  HOME_PROMO
  CATALOG
}

enum POSSessionStatus {
  OPEN
  CLOSED
}

enum POSSaleStatus {
  COMPLETED
  CANCELED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum POSPaymentMethod {
  CASH
  PIX
  DEBIT_CARD
  CREDIT_CARD
  MERCADO_PAGO
}

enum POSPaymentStatus {
  PENDING
  PAID
  REFUNDED
  CANCELED
}

enum CashMovementType {
  OPENING
  SALE
  CASH_IN
  CASH_OUT
  REFUND
  CLOSING
  ADJUSTMENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(CLIENT)
  document      String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  authenticators     Authenticator[]
  addresses          Address[]
  orders             Order[]
  carts              Cart[]
  reviews            Review[]
  wishlistItems      Wishlist[]
  adminProfile       AdminUser?
  inventoryMovements InventoryMovement[]
  posSessionsOpened  POSSession[]        @relation("POSSessionOpenedBy")
  posSessionsClosed  POSSession[]        @relation("POSSessionClosedBy")
  posSalesAsCashier  POSSale[]           @relation("POSSaleCashier")
  posSalesAsCustomer POSSale[]           @relation("POSSaleCustomer")
  cashMovements      CashMovement[]      @relation("CashMovementCreatedBy")

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
  @@map("authenticators")
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  label      String
  recipient  String
  zipCode    String
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String
  reference  String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?
  parentId    String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([active, sortOrder])
  @@map("categories")
}

model Product {
  id               String        @id @default(cuid())
  categoryId       String
  name             String
  slug             String        @unique
  sku              String        @unique
  barcode          String?       @unique
  ean              String?       @unique
  internalCode     String?       @unique
  brand            String        @default("XNutri")
  shortDescription String
  description      String
  price            Decimal       @db.Decimal(10, 2)
  compareAtPrice   Decimal?      @db.Decimal(10, 2)
  costPrice        Decimal?      @db.Decimal(10, 2)
  packagingCost    Decimal?      @db.Decimal(10, 2)
  desiredMargin    Decimal?      @db.Decimal(5, 2)
  estimatedTaxRate Decimal?      @db.Decimal(5, 2)
  status           ProductStatus @default(ACTIVE)
  featured         Boolean       @default(false)
  bestSeller       Boolean       @default(false)
  promotion        Boolean       @default(false)
  weightGrams      Int           @default(300)
  widthCm          Int           @default(16)
  heightCm         Int           @default(22)
  lengthCm         Int           @default(16)
  metaTitle        String?
  metaDescription  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  category      Category         @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  variants      ProductVariant[]
  inventory     Inventory[]
  reviews       Review[]
  orderItems    OrderItem[]
  posSaleItems  POSSaleItem[]
  cartItems     CartItem[]
  wishlistItems Wishlist[]

  @@index([categoryId, status])
  @@index([barcode])
  @@index([ean])
  @@index([internalCode])
  @@index([featured, bestSeller, promotion])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@map("product_images")
}

model ProductVariant {
  id              String   @id @default(cuid())
  productId       String
  name            String
  sku             String   @unique
  barcode         String?  @unique
  ean             String?  @unique
  internalCode    String?  @unique
  attributes      Json
  priceAdjustment Decimal  @default(0) @db.Decimal(10, 2)
  costPrice       Decimal? @db.Decimal(10, 2)
  packagingCost   Decimal? @db.Decimal(10, 2)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory    Inventory?
  orderItems   OrderItem[]
  posSaleItems POSSaleItem[]
  cartItems    CartItem[]

  @@index([productId, active])
  @@index([barcode])
  @@index([ean])
  @@index([internalCode])
  @@map("product_variants")
}

model Inventory {
  id                String   @id @default(cuid())
  productId         String
  variantId         String?  @unique
  quantity          Int      @default(0)
  reserved          Int      @default(0)
  lowStockThreshold Int      @default(5)
  available         Boolean  @default(true)
  updatedAt         DateTime @updatedAt

  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant?     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  movements InventoryMovement[]

  @@index([productId])
  @@map("inventory")
}

model InventoryMovement {
  id          String                @id @default(cuid())
  inventoryId String
  orderId     String?
  posSaleId   String?
  createdById String?
  type        InventoryMovementType
  quantity    Int
  reason      String
  balance     Int
  metadata    Json?
  createdAt   DateTime              @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  order     Order?    @relation(fields: [orderId], references: [id])
  posSale   POSSale?  @relation(fields: [posSaleId], references: [id])
  createdBy User?     @relation(fields: [createdById], references: [id])

  @@index([inventoryId, createdAt])
  @@index([orderId])
  @@index([posSaleId])
  @@map("inventory_movements")
}

model Coupon {
  id               String     @id @default(cuid())
  code             String     @unique
  description      String?
  type             CouponType
  value            Decimal    @db.Decimal(10, 2)
  minSubtotal      Decimal?   @db.Decimal(10, 2)
  maxDiscount      Decimal?   @db.Decimal(10, 2)
  productIds       String[]   @default([])
  categoryIds      String[]   @default([])
  startsAt         DateTime?
  endsAt           DateTime?
  usageLimit       Int?
  usageCount       Int        @default(0)
  perCustomerLimit Int?
  active           Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  orders Order[]
  carts  Cart[]

  @@index([active, startsAt, endsAt])
  @@map("coupons")
}

model Order {
  id                      String       @id @default(cuid())
  orderNumber             String       @unique
  userId                  String?
  couponId                String?
  shippingAddressId       String?
  shippingMethodId        String?
  pickupLocationId        String?
  customerName            String
  customerEmail           String
  customerPhone           String
  document                String?
  status                  OrderStatus  @default(PENDING)
  shippingType            ShippingType
  pickupProtocol          String?      @unique
  subtotal                Decimal      @db.Decimal(10, 2)
  discount                Decimal      @default(0) @db.Decimal(10, 2)
  shippingCost            Decimal      @default(0) @db.Decimal(10, 2)
  total                   Decimal      @db.Decimal(10, 2)
  grossRevenue            Decimal      @default(0) @db.Decimal(12, 2)
  netRevenue              Decimal      @default(0) @db.Decimal(12, 2)
  productsCost            Decimal      @default(0) @db.Decimal(12, 2)
  paymentFee              Decimal      @default(0) @db.Decimal(10, 2)
  fixedFee                Decimal      @default(0) @db.Decimal(10, 2)
  packagingCost           Decimal      @default(0) @db.Decimal(10, 2)
  estimatedTax            Decimal      @default(0) @db.Decimal(10, 2)
  shippingCostPaidByStore Decimal      @default(0) @db.Decimal(10, 2)
  grossProfit             Decimal      @default(0) @db.Decimal(12, 2)
  netProfit               Decimal      @default(0) @db.Decimal(12, 2)
  profitMargin            Decimal      @default(0) @db.Decimal(6, 2)
  shippingSnapshot        Json?
  pickupSnapshot          Json?
  notes                   String?
  paidAt                  DateTime?
  canceledAt              DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  user               User?               @relation(fields: [userId], references: [id])
  coupon             Coupon?             @relation(fields: [couponId], references: [id])
  shippingAddress    Address?            @relation(fields: [shippingAddressId], references: [id])
  shippingMethod     ShippingMethod?     @relation(fields: [shippingMethodId], references: [id])
  pickupLocation     PickupLocation?     @relation(fields: [pickupLocationId], references: [id])
  items              OrderItem[]
  payments           Payment[]
  inventoryMovements InventoryMovement[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("orders")
}

model OrderItem {
  id                    String   @id @default(cuid())
  orderId               String
  productId             String
  variantId             String?
  productName           String
  sku                   String
  imageUrl              String?
  quantity              Int
  unitPrice             Decimal  @db.Decimal(10, 2)
  total                 Decimal  @db.Decimal(10, 2)
  unitCost              Decimal  @default(0) @db.Decimal(10, 2)
  unitPackagingCost     Decimal  @default(0) @db.Decimal(10, 2)
  productCost           Decimal  @default(0) @db.Decimal(10, 2)
  discountAllocated     Decimal  @default(0) @db.Decimal(10, 2)
  paymentFeeAllocated   Decimal  @default(0) @db.Decimal(10, 2)
  fixedFeeAllocated     Decimal  @default(0) @db.Decimal(10, 2)
  shippingCostAllocated Decimal  @default(0) @db.Decimal(10, 2)
  taxAllocated          Decimal  @default(0) @db.Decimal(10, 2)
  grossProfit           Decimal  @default(0) @db.Decimal(10, 2)
  netProfit             Decimal  @default(0) @db.Decimal(10, 2)
  profitMargin          Decimal  @default(0) @db.Decimal(6, 2)
  attributes            Json?
  createdAt             DateTime @default(now())

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id              String          @id @default(cuid())
  orderId         String
  provider        PaymentProvider @default(MERCADO_PAGO)
  method          PaymentMethod   @default(UNKNOWN)
  status          PaymentStatus   @default(PENDING)
  amount          Decimal         @db.Decimal(10, 2)
  externalId      String?         @unique
  preferenceId    String?
  checkoutUrl     String?
  pixQrCode       String?
  pixQrCodeBase64 String?
  payload         Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([preferenceId])
  @@map("payments")
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  rating    Int
  title     String
  comment   String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([productId, approved])
  @@map("reviews")
}

model ShippingMethod {
  id              String           @id @default(cuid())
  name            String
  code            String           @unique
  provider        ShippingProvider
  active          Boolean          @default(true)
  basePrice       Decimal          @default(0) @db.Decimal(10, 2)
  freeAbove       Decimal?         @db.Decimal(10, 2)
  deliveryDaysMin Int              @default(1)
  deliveryDaysMax Int              @default(3)
  settings        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  orders Order[]
  carts  Cart[]

  @@index([active, provider])
  @@map("shipping_methods")
}

model PickupLocation {
  id           String   @id @default(cuid())
  name         String
  zipCode      String
  street       String
  number       String
  complement   String?
  district     String
  city         String
  state        String
  instructions String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
  carts  Cart[]

  @@index([active, city])
  @@map("pickup_locations")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlists")
}

model Cart {
  id               String    @id @default(cuid())
  userId           String?
  sessionId        String?
  couponId         String?
  shippingMethodId String?
  pickupLocationId String?
  shippingZipCode  String?
  shippingCost     Decimal   @default(0) @db.Decimal(10, 2)
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user           User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon         Coupon?         @relation(fields: [couponId], references: [id])
  shippingMethod ShippingMethod? @relation(fields: [shippingMethodId], references: [id])
  pickupLocation PickupLocation? @relation(fields: [pickupLocationId], references: [id])
  items          CartItem[]

  @@index([userId])
  @@index([sessionId])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@map("cart_items")
}

model AdminUser {
  id          String    @id @default(cuid())
  userId      String    @unique
  role        AdminRole @default(ADMIN)
  permissions Json
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  @@map("admin_users")
}

model AuditLog {
  id          String   @id @default(cuid())
  adminUserId String?
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id])

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model StoreSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

model FinancialSettings {
  id                             String   @id @default(cuid())
  name                           String   @unique @default("default")
  mercadoPagoRate                Decimal  @default(4.99) @db.Decimal(5, 2)
  fixedTransactionFee            Decimal  @default(0) @db.Decimal(10, 2)
  posCashRate                    Decimal  @default(0) @db.Decimal(5, 2)
  posPixRate                     Decimal  @default(0) @db.Decimal(5, 2)
  posDebitRate                   Decimal  @default(1.99) @db.Decimal(5, 2)
  posCreditRate                  Decimal  @default(3.99) @db.Decimal(5, 2)
  posMercadoPagoRate             Decimal  @default(4.99) @db.Decimal(5, 2)
  allowNegativeStock             Boolean  @default(false)
  estimatedTaxRate               Decimal  @default(0) @db.Decimal(5, 2)
  defaultPackagingCost           Decimal  @default(0) @db.Decimal(10, 2)
  minimumMargin                  Decimal  @default(20) @db.Decimal(5, 2)
  lowMarginAlert                 Decimal  @default(10) @db.Decimal(5, 2)
  defaultShippingCostPaidByStore Decimal  @default(0) @db.Decimal(10, 2)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  @@map("financial_settings")
}

model POSSession {
  id             String           @id @default(cuid())
  openedById     String
  closedById     String?
  openingAmount  Decimal          @default(0) @db.Decimal(10, 2)
  closingAmount  Decimal?         @db.Decimal(10, 2)
  expectedAmount Decimal          @default(0) @db.Decimal(10, 2)
  difference     Decimal          @default(0) @db.Decimal(10, 2)
  status         POSSessionStatus @default(OPEN)
  notes          String?
  openedAt       DateTime         @default(now())
  closedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  openedBy  User           @relation("POSSessionOpenedBy", fields: [openedById], references: [id])
  closedBy  User?          @relation("POSSessionClosedBy", fields: [closedById], references: [id])
  sales     POSSale[]
  movements CashMovement[]

  @@index([openedById, status])
  @@index([status, openedAt])
  @@map("pos_sessions")
}

model POSSale {
  id                 String           @id @default(cuid())
  saleNumber         String           @unique
  customerId         String?
  cashierId          String
  sessionId          String
  subtotal           Decimal          @db.Decimal(12, 2)
  discountTotal      Decimal          @default(0) @db.Decimal(10, 2)
  total              Decimal          @db.Decimal(12, 2)
  amountReceived     Decimal          @default(0) @db.Decimal(12, 2)
  changeAmount       Decimal          @default(0) @db.Decimal(10, 2)
  costTotal          Decimal          @default(0) @db.Decimal(12, 2)
  feeTotal           Decimal          @default(0) @db.Decimal(10, 2)
  packagingCost      Decimal          @default(0) @db.Decimal(10, 2)
  estimatedTax       Decimal          @default(0) @db.Decimal(10, 2)
  grossProfit        Decimal          @default(0) @db.Decimal(12, 2)
  netProfit          Decimal          @default(0) @db.Decimal(12, 2)
  margin             Decimal          @default(0) @db.Decimal(6, 2)
  status             POSSaleStatus    @default(COMPLETED)
  paymentStatus      POSPaymentStatus @default(PAID)
  cancellationReason String?
  receiptToken       String           @unique
  fiscalStatus       String           @default("NOT_REQUESTED")
  fiscalProvider     String?
  fiscalPayload      Json?
  notes              String?
  canceledAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  customer           User?               @relation("POSSaleCustomer", fields: [customerId], references: [id])
  cashier            User                @relation("POSSaleCashier", fields: [cashierId], references: [id])
  session            POSSession          @relation(fields: [sessionId], references: [id])
  items              POSSaleItem[]
  payments           POSPayment[]
  cashMovements      CashMovement[]
  inventoryMovements InventoryMovement[]

  @@index([cashierId, createdAt])
  @@index([customerId, createdAt])
  @@index([sessionId, createdAt])
  @@index([status, createdAt])
  @@map("pos_sales")
}

model POSSaleItem {
  id                  String   @id @default(cuid())
  saleId              String
  productId           String
  variantId           String?
  productNameSnapshot String
  skuSnapshot         String
  barcodeSnapshot     String?
  quantity            Int
  returnedQuantity    Int      @default(0)
  unitPrice           Decimal  @db.Decimal(10, 2)
  unitCost            Decimal  @default(0) @db.Decimal(10, 2)
  unitPackagingCost   Decimal  @default(0) @db.Decimal(10, 2)
  discount            Decimal  @default(0) @db.Decimal(10, 2)
  subtotal            Decimal  @db.Decimal(10, 2)
  total               Decimal  @db.Decimal(10, 2)
  grossProfit         Decimal  @default(0) @db.Decimal(10, 2)
  netProfit           Decimal  @default(0) @db.Decimal(10, 2)
  margin              Decimal  @default(0) @db.Decimal(6, 2)
  attributes          Json?
  createdAt           DateTime @default(now())

  sale    POSSale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@index([variantId])
  @@map("pos_sale_items")
}

model POSPayment {
  id                String           @id @default(cuid())
  saleId            String
  method            POSPaymentMethod
  amount            Decimal          @db.Decimal(10, 2)
  fee               Decimal          @default(0) @db.Decimal(10, 2)
  status            POSPaymentStatus @default(PAID)
  amountReceived    Decimal?         @db.Decimal(10, 2)
  changeAmount      Decimal?         @db.Decimal(10, 2)
  externalReference String?
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  sale POSSale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([method, createdAt])
  @@map("pos_payments")
}

model CashMovement {
  id          String           @id @default(cuid())
  sessionId   String
  saleId      String?
  type        CashMovementType
  amount      Decimal          @db.Decimal(10, 2)
  reason      String
  createdById String
  createdAt   DateTime         @default(now())

  session   POSSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sale      POSSale?   @relation(fields: [saleId], references: [id])
  createdBy User       @relation("CashMovementCreatedBy", fields: [createdById], references: [id])

  @@index([sessionId, createdAt])
  @@index([saleId])
  @@index([type, createdAt])
  @@map("cash_movements")
}

model Banner {
  id        String         @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String
  ctaLabel  String?
  ctaHref   String?
  location  BannerLocation
  active    Boolean        @default(true)
  sortOrder Int            @default(0)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([location, active, sortOrder])
  @@map("banners")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String   @default("home")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

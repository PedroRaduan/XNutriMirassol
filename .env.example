# ============================================================
# XNutri - desenvolvimento local
# Copie este arquivo para .env.local e preencha os valores.
# Nunca envie .env.local, senhas ou tokens reais para o GitHub.
# ============================================================

# Aplicação e autenticação
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=
AUTH_TRUST_HOST=true
AUTH_SESSION_MAX_AGE_SECONDS=28800
XNUTRI_DEPLOYMENT=local

# PostgreSQL
# Local: conexão direta com o container do docker-compose.yml.
# Produção: DATABASE_URL deve ser a URL pooler do Neon.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/xnutri?schema=public
# Produção: URL direta do Neon, usada por migrations, seed e criação do admin.
DIRECT_URL=
# Aliases opcionais aceitos por integrações Vercel/Prisma.
POSTGRES_PRISMA_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
DATABASE_URL_POOLED=
DATABASE_URL_UNPOOLED=
NEON_DATABASE_URL=
NEON_DATABASE_URL_UNPOOLED=
DATABASE_POOL_MAX=5
PRISMA_LOG_ERRORS=false

# Mercado Pago
MERCADO_PAGO_ENVIRONMENT=sandbox
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=xnutri

# Correios (reservado para a integração oficial de frete)
CORREIOS_USER=
CORREIOS_PASSWORD=
CORREIOS_TOKEN=
CORREIOS_CARTAO_POSTAGEM=
CORREIOS_CONTRATO=
CORREIOS_DR=

# Primeiro administrador (usado por npm run admin:create)
ADMIN_EMAIL=admin@xnutri.com.br
ADMIN_PASSWORD=
ADMIN_NAME=Administrador XNutri

# Loja, PDV e PWA
NEXT_PUBLIC_STORE_NAME=XNutri
NEXT_PUBLIC_STORE_CITY=Mirassol
NEXT_PUBLIC_STORE_STATE=SP
NEXT_PUBLIC_PDV_ENABLED=true
PDV_RECEIPT_FOOTER=Obrigado por comprar na XNutri Mirassol.
PDV_ALLOW_NEGATIVE_STOCK=false
PDV_CASHIER_MAX_DISCOUNT_PERCENT=10
NEXT_PUBLIC_PWA_NAME=XNutri Mirassol
NEXT_PUBLIC_PWA_SHORT_NAME=XNutri
